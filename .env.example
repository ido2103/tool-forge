# Toolforge configuration — copy to .env and fill in.
# `.env` is gitignored; this file is committed. See src/toolforge/config.py.

# ── Orchestrator model (Anthropic) ──────────────────────────────────────────
# "api_key" (default) or "oauth" (Claude Pro/Max subscription credentials).
TOOLFORGE_ANTHROPIC_AUTH_MODE=api_key
# Required when auth_mode=api_key. Standard Anthropic variable name.
ANTHROPIC_API_KEY=sk-ant-...
# Required when auth_mode=oauth: path to a JSON file of the shape
# {"accessToken": ..., "refreshToken": ..., "expiresAt": <epoch ms>}.
# Provisioned externally (a Zeemon-provisioned creds file works); refreshed in
# place. NOTE: refresh tokens are single-use — don't share one creds file
# between two concurrently running apps.
#TOOLFORGE_ANTHROPIC_OAUTH_CREDENTIALS_PATH=~/.config/toolforge/anthropic_oauth.json
# Default orchestrator model. claude-sonnet-4-6 is the cheaper option.
TOOLFORGE_ANTHROPIC_MODEL=claude-opus-4-8
# Optional knobs:
#TOOLFORGE_ANTHROPIC_BASE_URL=                     # override API endpoint (proxies)
#TOOLFORGE_ANTHROPIC_CACHE_TTL=ephemeral           # or "1h"
#TOOLFORGE_ANTHROPIC_EXTENDED_THINKING=adaptive    # or "off" (use "off" if the
#                                                  # configured model rejects adaptive thinking)

# ── Forge worker (OpenAI-compatible server: vLLM / llama.cpp) ───────────────
# The client targets http://HOST:PORT/v1
TOOLFORGE_WORKER_HOST=127.0.0.1
TOOLFORGE_WORKER_PORT=8000
TOOLFORGE_WORKER_MODEL=Qwen/Qwen3.6-27B
# Only needed if the server enforces auth (e.g. vLLM --api-key); defaults to "EMPTY".
#TOOLFORGE_WORKER_API_KEY=EMPTY
