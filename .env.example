# Toolforge configuration — copy to .env and fill in.
# `.env` is gitignored; this file is committed. See src/toolforge/config.py.

# ── Orchestrator model (Anthropic) ──────────────────────────────────────────
# "api_key" (default) or "oauth" (Claude Pro/Max subscription credentials).
TOOLFORGE_ANTHROPIC_AUTH_MODE=api_key
# Required when auth_mode=api_key. Standard Anthropic variable name.
ANTHROPIC_API_KEY=sk-ant-...
# Required when auth_mode=oauth: path to a JSON file of the shape
# {"accessToken": ..., "refreshToken": ..., "expiresAt": <epoch ms>}.
# Provisioned externally (a Zeemon-provisioned creds file works); refreshed in
# place. NOTE: refresh tokens are single-use — don't share one creds file
# between two concurrently running apps.
#TOOLFORGE_ANTHROPIC_OAUTH_CREDENTIALS_PATH=~/.config/toolforge/anthropic_oauth.json
# Default orchestrator model. claude-sonnet-4-6 is the cheaper option.
TOOLFORGE_ANTHROPIC_MODEL=claude-opus-4-8
# Optional knobs:
#TOOLFORGE_ANTHROPIC_BASE_URL=                     # override API endpoint (proxies)
#TOOLFORGE_ANTHROPIC_CACHE_TTL=5m                  # cache TTL: "5m" (default) or "1h";
#                                                  # cache type is always "ephemeral"
#TOOLFORGE_ANTHROPIC_EXTENDED_THINKING=adaptive    # or "off" (use "off" if the
#                                                  # configured model rejects adaptive thinking)

# ── Forge worker (implements tools against the authored tests) ──────────────
# Backend: "api" (default; a cheaper Anthropic model via the orchestrator's
# credentials) or "local" (OpenAI-compatible server: vLLM / llama.cpp / LM Studio).
# Invariant enforced at boot: the worker model must differ from both the
# orchestrator's and the test author's (cross-model separation).
#TOOLFORGE_WORKER_BACKEND=api
#TOOLFORGE_WORKER_API_MODEL=claude-haiku-4-5
# local mode only — the client targets http://HOST:PORT/v1
TOOLFORGE_WORKER_HOST=127.0.0.1
TOOLFORGE_WORKER_PORT=8000
TOOLFORGE_WORKER_MODEL=Qwen/Qwen3.6-27B
# Only needed if the server enforces auth (e.g. vLLM --api-key); defaults to "EMPTY".
#TOOLFORGE_WORKER_API_KEY=EMPTY
# Build-loop budgets
#TOOLFORGE_WORKER_MAX_ATTEMPTS=4          # harness verifications before escalating
#TOOLFORGE_WORKER_MAX_ITERATIONS=15       # tool-call iterations per attempt
#TOOLFORGE_WORKER_MAX_TOKENS=8000         # output-token cap per worker call
#TOOLFORGE_WORKER_TIMEOUT_SECONDS=1800    # wall-clock budget for one build

# ── Forge test author (adversarial tests, frontier-tier) ────────────────────
#TOOLFORGE_TEST_AUTHOR_MODEL=                       # default: empty → the orchestrator model
#TOOLFORGE_TEST_AUTHOR_MAX_ATTEMPTS=3               # author→validate retries before the forge gives up
#TOOLFORGE_TEST_AUTHOR_MAX_TOKENS=16000             # output-token cap per authoring call
#TOOLFORGE_TEST_AUTHOR_MIN_TESTS=5                  # reject suites smaller than this
#TOOLFORGE_TEST_AUTHOR_TIMEOUT_SECONDS=1500         # wall-clock budget for one authoring run

# ── Orchestrator (agent loop) ───────────────────────────────────────────────
#TOOLFORGE_ORCHESTRATOR_MAX_TOKENS_PER_TURN=32000   # output-token cap per API call
#TOOLFORGE_ORCHESTRATOR_MAX_ITERATIONS=30           # tool-call iterations before wrap-up
#TOOLFORGE_ORCHESTRATOR_SYSTEM_PROMPT_PATH=         # override the bundled system.md
#TOOLFORGE_ORCHESTRATOR_RUNS_DIR=runs               # per-run JSONL transcripts land here

# ── Sandbox (run_bash Docker container) ─────────────────────────────────────
#TOOLFORGE_SANDBOX_IMAGE=python:3.12-slim
#TOOLFORGE_SANDBOX_NETWORK=on                       # "on" (bridge) or "none" (isolated)
#TOOLFORGE_SANDBOX_WORKSPACE_PATH=./workspace       # host dir mounted rw at /workspace
#TOOLFORGE_SANDBOX_TOOLS_PATH=./tools               # forged-tool store, mounted ro at /tools
#TOOLFORGE_SANDBOX_COMMAND_TIMEOUT=60               # per-command seconds (1..600)
#TOOLFORGE_SANDBOX_OUTPUT_CAP=100000                # per-command output byte cap
